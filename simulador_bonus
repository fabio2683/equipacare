// KPI atingimento store (id -> value 0-150)
let KPI = {};
// Carteira data: CD[personId] = {moedasAjustadas, contratos:[{nome,satA,resA,conA}]}
let CD = {};

// ══════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════
function n(id){ return parseFloat(document.getElementById(id)?.value)||0; }
function fBRL(v){ return 'R$\u00a0'+Math.round(v).toLocaleString('pt-BR'); }
function fCoins(v){ return Math.round(v).toLocaleString('pt-BR'); }
function fMult(v){ return '\u00d7'+v.toFixed(2).replace('.',','); }
function fPct(v){ return (v*100).toFixed(1).replace('.',',')+'%'; }

function getScale(){
  return {
    patMin: n('p_patMin')/100 || 0.8,
    patMax: n('p_patMax')/100 || 1.2,
    multMin: n('p_multMin') || 0.8,
    multMax: n('p_multMax') || 1.2,
  };
}

function kpiMult(ating){ // ating in 0-150 range (percentage points)
  const a = ating/100;
  const sc = getScale();
  if(a < sc.patMin) return 0;
  if(a <= 1.0) return sc.multMin + (1-sc.multMin)*((a-sc.patMin)/(1-sc.patMin));
  if(a <= sc.patMax) return 1.0 + (sc.multMax-1)*((a-1)/(sc.patMax-1));
  return sc.multMax;
}

function abClass(ating){
  const a = ating/100;
  const sc = getScale();
  if(a < sc.patMin) return {cls:'ab-z', lbl:'Abaixo m\u00edn'};
  if(a <= 1.0) return {cls:'ab-l', lbl:'M\u00edn\u2192Alvo'};
  if(a <= sc.patMax) return {cls:'ab-o', lbl:'\u2265 Alvo'};
  return {cls:'ab-m', lbl:'Acima m\u00e1x'};
}

function blockCalc(gk){
  const grp = G[gk];
  const sc = getScale();
  let gateTriggered = false;
  for(const kpi of grp.kpis){
    const a = (KPI[kpi.id]||100)/100;
    if(kpi.g && a < sc.patMin){ gateTriggered=true; break; }
  }
  if(gateTriggered) return {mult:0, triggered:true};
  let mult = 0;
  for(const kpi of grp.kpis){
    mult += kpi.p * kpiMult(KPI[kpi.id]||100);
  }
  return {mult, triggered:false};
}

function calcPerson(p){
  // Corporate
  const corp = blockCalc('Corporativo');
  const coinsCorp = p.m * p.wC * corp.mult;

  // Area (multi-scope)
  let coinsArea = 0;
  const areaDetails = [];
  for(const scope of p.sA){
    const split = p.areaSplit[scope]||0;
    const bc = blockCalc(scope);
    const sc = p.m * p.wA * split * bc.mult;
    coinsArea += sc;
    areaDetails.push({scope, split, mult:bc.mult, triggered:bc.triggered, coins:sc});
  }

  // Carteira
  let coinsCart = 0;
  const cartDetails = [];
  if(p.wK > 0){
    const cd = CD[p.id] || {moedasAjustadas: p.m*p.wK, contratos:[]};
    const ma = cd.moedasAjustadas;
    const nc = cd.contratos.length;
    const wRes = n('p_wRes')/100 || 0.5;
    const wCon = n('p_wCon')/100 || 0.5;
    const sc = getScale();
    if(nc===0){
      coinsCart = 0;
    } else {
      for(const c of cd.contratos){
        const base = ma/nc;
        let cCoins=0;
        const satPassed = (c.satA/100) >= sc.patMin;
        if(!satPassed){
          cCoins=0;
        } else {
          cCoins = base*(wRes*kpiMult(c.resA)+wCon*kpiMult(c.conA));
        }
        coinsCart += cCoins;
        cartDetails.push({...c, base, cCoins, satPassed});
      }
    }
    cartDetails._ma = ma;
    cartDetails._nc = nc;
  }

  const tot = coinsCorp + coinsArea + coinsCart;
  return {coinsCorp, coinsArea, coinsCart, tot, areaDetails, cartDetails, corp};
}

function getPool(){
  const llMin = n('p_llMin');
  const llReal = n('p_llReal');
  const dist = n('p_dist')/100;
  if(llReal <= llMin) return 0;
  return (llReal-llMin)*dist*1000000;
}

