function recalcKpiCard(gk){
  // Update only badge and multiplier display — don't rebuild card
  const grp=G[gk];
  const bc=blockCalc(gk);
  const multEl=document.getElementById('mult_'+gk);
  const krEl=document.getElementById('kr_'+gk);
  const gwEl=document.getElementById('gw_'+gk);
  if(multEl) multEl.textContent=fMult(bc.mult);
  if(krEl) krEl.textContent=fMult(bc.mult);
  if(gwEl) gwEl.style.display=bc.triggered?'block':'none';
  grp.kpis.forEach(kpi=>{
    const v=KPI[kpi.id]||100;
    const ab=abClass(v);
    const abEl=document.getElementById('ab_'+kpi.id);
    if(abEl){abEl.className='ab '+ab.cls;abEl.textContent=ab.lbl;}
  });
  recalc();
}

function updateGateTags(){
  for(const [gk,grp] of Object.entries(G)){
    grp.kpis.forEach(kpi=>{
      const el=document.getElementById('gt_'+kpi.id);
      if(el) el.style.display=kpi.g?'':'none';
    });
  }
}

function recalc(){
  // Update pool display
  const pool=getPool();
  const pvEl=document.getElementById('pool-val');
  if(pvEl) pvEl.textContent=fBRL(pool);

  // Update all KPI card multipliers
  for(const gk of Object.keys(G)){
    const bc=blockCalc(gk);
    const multEl=document.getElementById('mult_'+gk);
    const krEl=document.getElementById('kr_'+gk);
    const gwEl=document.getElementById('gw_'+gk);
    if(multEl) multEl.textContent=fMult(bc.mult);
    if(krEl) krEl.textContent=fMult(bc.mult);
    if(gwEl) gwEl.style.display=bc.triggered?'block':'none';
    G[gk].kpis.forEach(kpi=>{
      const v=KPI[kpi.id]||100;
      const ab=abClass(v);
      const abEl=document.getElementById('ab_'+kpi.id);
      if(abEl){abEl.className='ab '+ab.cls;abEl.textContent=ab.lbl;}
    });
  }

  // Calc all people
  const results=E.map(p=>({p,r:calcPerson(p)}));
  const totalCoins=results.reduce((s,x)=>s+x.r.tot,0);
  const totalAlvo=E.reduce((s,p)=>s+p.m,0);

  // Update result tab metrics
  const metricsDiv=document.getElementById('res-metrics');
  if(metricsDiv){
    metricsDiv.innerHTML=`
      <div class="mbox navy"><div class="mv">${fBRL(pool)}</div><div class="ml">Pool de B\u00f4nus</div></div>
      <div class="mbox"><div class="mv">${fCoins(totalAlvo)}</div><div class="ml">Total Moedas Alvo</div></div>
      <div class="mbox steel"><div class="mv">${fCoins(totalCoins)}</div><div class="ml">Total Moedas Resultado</div></div>
      <div class="mbox lime"><div class="mv">${fBRL(pool)}</div><div class="ml">Custo Total (pool distribu\u00eddo)</div></div>
    `;
  }

  // Update result table
  const tbody=document.getElementById('res-tbody');
  if(!tbody) return;
  tbody.innerHTML='';
  results.forEach(({p,r},idx)=>{
    const pct=totalCoins>0?r.tot/totalCoins:0;
    const payment=pct*pool;
    const delta=r.tot-p.m;
    const deltaSign=delta>=0?'+':'';
    const dCls=delta>=0?'c-green':'c-red';
    const barW=totalAlvo>0?Math.min(100,r.tot/totalAlvo*100):0;
    const status=pool===0?'<span class="pill p-red">Gatilho n\u00e3o atingido</span>':
                  Math.abs(r.tot-p.m)<0.5?'<span class="pill p-navy">Alvo</span>':
                  r.tot>p.m+0.5?'<span class="pill p-green">Acima alvo</span>':
                  r.tot>0?'<span class="pill p-orange">Parcial</span>':
                  '<span class="pill p-red">Zero</span>';

    const tr=document.createElement('tr');
    tr.className='row-exp';
    tr.id='tr_'+p.id;
    tr.innerHTML=`
      <td><button class="exp-btn" id="eb_${p.id}" onclick="toggleDet('${p.id}',this)">+</button></td>
      <td class="fw7">${p.nome}</td>
      <td style="color:var(--muted);font-size:12px">${p.cargo}</td>
      <td style="text-align:right">${fCoins(p.m)}</td>
      <td style="text-align:right;font-weight:700">${fCoins(r.tot)}</td>
      <td style="text-align:right" class="${dCls}">${deltaSign}${fCoins(delta)}</td>
      <td style="text-align:right">${fPct(pct)}</td>
      <td style="text-align:right;font-weight:700;color:var(--navy)">${fBRL(payment)}</td>
      <td><div style="background:var(--border);border-radius:4px;height:7px;"><div class="bar" style="width:${barW.toFixed(1)}%;background:var(--teal);"></div></div></td>
      <td>${status}</td>
    `;
    tbody.appendChild(tr);

    // Detail row
    const det=document.createElement('tr');
    det.className='det-row';
    det.id='det_'+p.id;
    const detTd=document.createElement('td');
    detTd.className='det-cell';
    detTd.colSpan=10;
    detTd.innerHTML=buildDetailHTML(p,r,pool,totalCoins,payment);
    det.appendChild(detTd);
    tbody.appendChild(det);
  });
}

function buildDetailHTML(p,r,pool,totalCoins,payment){
  let html='<div class="det-inner">';

  // Corporate block
  const corpGrp=G['Corporativo'];
  const corpZero=r.corp.triggered;
  html+=`<div class="blk ${corpZero?'zeroed':''}">
    <div class="blk-title">Corporativo</div>
    <div class="blk-w">Peso ${Math.round(p.wC*100)}%</div>
    ${corpGrp.kpis.map(kpi=>`<div class="blk-kpi"><span>${kpi.nome}</span><span>${KPI[kpi.id]||100}%</span></div>`).join('')}
    ${corpZero?'<div class="rbox" style="margin-top:6px;font-size:11px;">Gatilho ativado</div>':''}
    <div class="blk-res">
      <span class="blk-mult-tag">${fMult(r.corp.mult)}</span>
      <span class="blk-coins">${fCoins(r.coinsCorp)} moedas</span>
    </div>
  </div>`;

  // Area blocks
  if(r.areaDetails.length===0 && p.wA>0){
    html+=`<div class="blk"><div class="blk-title">&Aacute;rea</div><div class="blk-w">Peso ${Math.round(p.wA*100)}%</div><p style="font-size:12px;color:var(--muted)">Sem escopo definido.</p></div>`;
  }
  r.areaDetails.forEach(ad=>{
    const grp=G[ad.scope];
    html+=`<div class="blk ${ad.triggered?'zeroed':''}">
      <div class="blk-title">&Aacute;rea: ${ad.scope}</div>
      <div class="blk-w">Split ${Math.round(ad.split*100)}%</div>
      ${grp.kpis.map(kpi=>`<div class="blk-kpi"><span>${kpi.nome}</span><span>${KPI[kpi.id]||100}%</span></div>`).join('')}
      ${ad.triggered?'<div class="rbox" style="margin-top:6px;font-size:11px;">Gatilho ativado</div>':''}
      <div class="blk-res">
        <span class="blk-mult-tag">${fMult(ad.mult)}</span>
        <span class="blk-coins">${fCoins(ad.coins)} moedas</span>
      </div>
    </div>`;
  });

  // Carteira block
  if(p.wK>0){
    const cd=CD[p.id]||{moedasAjustadas:p.m*p.wK,contratos:[]};
    let cartRows='';
    if(cd.contratos.length===0){
      cartRows='<tr><td colspan="4" style="color:var(--muted);font-size:12px;text-align:center;">Nenhum contrato cadastrado</td></tr>';
    } else {
      const nc=cd.contratos.length;
      const ma=cd.moedasAjustadas;
      const sc=getScale();
      const wRes=n('p_wRes')/100||0.5;
      const wCon=n('p_wCon')/100||0.5;
      cd.contratos.forEach((c,ci)=>{
        const base=ma/nc;
        const satPassed=(c.satA/100)>=sc.patMin;
        let cCoins=0;
        if(satPassed) cCoins=base*(wRes*kpiMult(c.resA)+wCon*kpiMult(c.conA));
        cartRows+=`<tr>
          <td>${c.nome}</td>
          <td>${c.satA}% <span class="pill ${satPassed?'p-green':'p-red'}">${satPassed?'&#10003;':'&#10007;'}</span></td>
          <td>${c.resA}% / ${c.conA}%</td>
          <td style="font-weight:700">${fCoins(cCoins)}</td>
        </tr>`;
      });
    }
    html+=`<div class="blk">
      <div class="blk-title">Carteira (GQM e ATE)</div>
      <div class="blk-w">Peso ${Math.round(p.wK*100)}%</div>
      <table class="tbl" style="font-size:11px;margin-top:4px;">
        <thead><tr><th>Contrato</th><th>Satisfa&ccedil;&atilde;o</th><th>Res / Conf</th><th>Moedas</th></tr></thead>
        <tbody>${cartRows}</tbody>
      </table>
      <div class="blk-res">
        <span class="blk-mult-tag">Carteira</span>
        <span class="blk-coins">${fCoins(r.coinsCart)} moedas</span>
      </div>
    </div>`;
  }

  // Summary
  const pct=totalCoins>0?r.tot/totalCoins:0;
  html+=`<div class="blk-total">
    <div>
      <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;">Total</div>
      <div style="font-size:18px;font-weight:700;color:var(--navy)">${fCoins(r.tot)} moedas</div>
      <div style="font-size:11px;color:var(--muted)">Alvo: ${fCoins(p.m)} &nbsp;|&nbsp; ${fPct(p.m>0?r.tot/p.m:0)} do alvo</div>
    </div>
    <div style="text-align:right">
      <div style="font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;">Pagamento estimado</div>
      <div style="font-size:20px;font-weight:700;color:var(--navy)">${fBRL(payment)}</div>
      <div style="font-size:11px;color:var(--muted)">${fPct(pct)} do pool</div>
    </div>
  </div>`;

  html+='</div>';
  return html;
}

function toggleDet(pid, btn){
  const det=document.getElementById('det_'+pid);
  if(!det) return;
  const open=det.classList.toggle('open');
  btn.classList.toggle('open',open);
