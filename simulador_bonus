function updatePersonMoedas(idx, val){
  const p = E[idx];
  const oldDef = Math.round(p.m * p.wK);
  p.m = +val;
  if(p.wK > 0 && CD[p.id]){
    if(Math.abs(CD[p.id].moedasAjustadas - oldDef) < 1){
      CD[p.id].moedasAjustadas = Math.round(p.m * p.wK);
      const maEl = document.getElementById('ma_'+p.id);
      if(maEl) maEl.value = CD[p.id].moedasAjustadas;
      refreshCartCard(p.id);
    }
  }
  recalc();
}

function updatePersonWK(idx, val){
  const p = E[idx];
  const oldWK = p.wK;
  const oldDef = Math.round(p.m * oldWK);
  p.wK = +val/100;
  if(p.wK > 0){
    if(!CD[p.id]){
      CD[p.id] = {moedasAjustadas: Math.round(p.m * p.wK), contratos:defaultContratos()};
    } else if(Math.abs(CD[p.id].moedasAjustadas - oldDef) < 1){
      CD[p.id].moedasAjustadas = Math.round(p.m * p.wK);
    }
    buildCartSection();
  }
  recalc();
}

