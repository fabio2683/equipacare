function defaultContratos(){ return [{nome:'Contrato 1',satA:100,resA:100,conA:100}]; }

function initCD(){
  E.forEach(p=>{
    if(p.wK>0 && !CD[p.id]){
      CD[p.id]={moedasAjustadas:Math.round(p.m*p.wK),contratos:defaultContratos()};
    }
  });
}

function initKPI(){
  for(const grp of Object.values(G)){
    for(const kpi of grp.kpis){
      if(KPI[kpi.id]===undefined) KPI[kpi.id]=100;
    }
  }
}

function showTab(id, btn){
  document.querySelectorAll('.pane').forEach(p=>p.classList.remove('act'));
  document.querySelectorAll('.nav button').forEach(b=>b.classList.remove('act'));
  document.getElementById('tab-'+id).classList.add('act');
  btn.classList.add('act');
  if(id==='resultado') recalc();
}

