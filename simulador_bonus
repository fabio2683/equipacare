function exportExcel(){
  if(typeof XLSX==='undefined'){alert('SheetJS n\u00e3o carregado. Verifique a conex\u00e3o.');return;}
  const wb=XLSX.utils.book_new();

  // Sheet 1: Parâmetros
  const param=[
    ['Parametro','Valor'],
    ['LL Minimo (R$ M)', n('p_llMin')],
    ['LL Realizado (R$ M)', n('p_llReal')],
    ['% Distribuicao', n('p_dist')],
    ['PatMin %', n('p_patMin')],
    ['PatMax %', n('p_patMax')],
    ['MultMin', n('p_multMin')],
    ['MultMax', n('p_multMax')],
    ['Peso Resultado Carteira %', n('p_wRes')],
    ['Peso Conformidade Carteira %', n('p_wCon')],
  ];
  E.forEach(p=>{
    param.push([p.id+'_m', p.m]);
    param.push([p.id+'_wC', Math.round(p.wC*100)]);
    param.push([p.id+'_wA', Math.round(p.wA*100)]);
    param.push([p.id+'_wK', Math.round(p.wK*100)]);
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(param), 'Parametros');

  // Sheet 2: KPI Atingimento
  const kpiSheet=[['Grupo','KPI_ID','Nome','Atingimento %','Gatilho']];
  for(const [gk,grp] of Object.entries(G)){
    grp.kpis.forEach(kpi=>{
      kpiSheet.push([gk, kpi.id, kpi.nome, KPI[kpi.id]||100, kpi.g?'Sim':'Nao']);
    });
  }
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(kpiSheet), 'Atingimento_KPIs');

  // Sheet 3: Carteiras
  const cartSheet=[['Pessoa_ID','Moedas Ajustadas','Contrato','Satisfacao %','Resultado %','Conformidade %']];
  E.filter(p=>p.wK>0).forEach(p=>{
    const cd=CD[p.id];
    if(!cd) return;
    cartSheet.push([p.id, cd.moedasAjustadas,'','','','']);
    cd.contratos.forEach(c=>{
      cartSheet.push([p.id,'', c.nome, c.satA, c.resA, c.conA]);
    });
  });
  XLSX.utils.book_append_sheet(wb, XLSX.utils.aoa_to_sheet(cartSheet), 'Carteiras');

  XLSX.writeFile(wb, 'simulador_rvv_equipacare.xlsx');
}

function importExcel(){
  document.getElementById('file-input').click();
}

function handleImport(ev){
  const file=ev.target.files[0];
  if(!file) return;
  if(typeof XLSX==='undefined'){alert('SheetJS n\u00e3o carregado.');return;}
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      const wb=XLSX.read(e.target.result,{type:'array'});

      // Parametros
      const ps=XLSX.utils.sheet_to_json(wb.Sheets['Parametros'],{header:1});
      const pm={};
      ps.slice(1).forEach(r=>{ if(r[0]) pm[r[0]]=r[1]; });
      ['p_llMin','p_llReal','p_dist','p_patMin','p_patMax','p_multMin','p_multMax','p_wRes','p_wCon'].forEach(id=>{
        const lblMap={'p_llMin':'LL Minimo (R$ M)','p_llReal':'LL Realizado (R$ M)','p_dist':'% Distribuicao',
          'p_patMin':'PatMin %','p_patMax':'PatMax %','p_multMin':'MultMin','p_multMax':'MultMax',
          'p_wRes':'Peso Resultado Carteira %','p_wCon':'Peso Conformidade Carteira %'};
        const el=document.getElementById(id);
        if(el && pm[lblMap[id]]!==undefined) el.value=pm[lblMap[id]];
      });
      E.forEach(p=>{
        if(pm[p.id+'_m']!==undefined) p.m=+pm[p.id+'_m'];
        if(pm[p.id+'_wC']!==undefined) p.wC=+pm[p.id+'_wC']/100;
        if(pm[p.id+'_wA']!==undefined) p.wA=+pm[p.id+'_wA']/100;
        if(pm[p.id+'_wK']!==undefined) p.wK=+pm[p.id+'_wK']/100;
      });

      // KPI Atingimento
      const ks=XLSX.utils.sheet_to_json(wb.Sheets['Atingimento_KPIs'],{header:1});
      ks.slice(1).forEach(r=>{
        if(r[1]) KPI[r[1]]=+r[3]||100;
        if(r[1] && r[4]){
          for(const grp of Object.values(G)){
            const kpi=grp.kpis.find(k=>k.id===r[1]);
            if(kpi) kpi.g=(r[4]==='Sim');
          }
        }
      });

      // Carteiras
      const cs=XLSX.utils.sheet_to_json(wb.Sheets['Carteiras'],{header:1});
      let curPid=null;
      cs.slice(1).forEach(r=>{
        if(!r[0]) return;
        if(r[1]!=='' && r[1]!==undefined && r[2]===''){
          curPid=r[0];
          CD[curPid]={moedasAjustadas:+r[1]||0,contratos:[]};
        } else if(r[2]){
          if(!curPid) curPid=r[0];
          if(!CD[curPid]) CD[curPid]={moedasAjustadas:0,contratos:[]};
          CD[curPid].contratos.push({nome:r[2],satA:+r[3]||100,resA:+r[4]||100,conA:+r[5]||100});
        }
      });

      // Rebuild UI
      buildEligTable();
      buildAreaSplit();
      buildKpiParams();
      buildKpiCards();
      buildCartSection();
      recalc();
      alert('Importa\u00e7\u00e3o conclu\u00edda!');
    } catch(err){
      alert('Erro ao importar: '+err.message);
    }
  };
  reader.readAsArrayBuffer(file);
  ev.target.value='';
}

