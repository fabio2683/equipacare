      <span class="krv" id="kr_${gk}">${fMult(1)}</span>
    </div>
    </div></div>`;
  return html;
}

function buildCartSection(){
  const div = document.getElementById('cart-section');
  div.innerHTML='';
  const cartPeople = E.filter(p=>p.wK>0);
  if(!cartPeople.length){div.innerHTML='<p style="color:var(--muted)">Nenhum eleg\u00edvel com peso de carteira &gt; 0.</p>';return;}
  cartPeople.forEach(p=>{
    if(!CD[p.id]) CD[p.id]={moedasAjustadas:Math.round(p.m*p.wK), contratos:[]};
    const cd=CD[p.id];
    div.innerHTML+=buildCartCard(p,cd);
  });
}

function buildCartCard(p,cd){
  const sc=getScale();
  const nc=cd.contratos.length;
  const approved=cd.contratos.filter(c=>(c.satA/100)>=sc.patMin).length;
  const ma=cd.moedasAjustadas;
  const wRes=n('p_wRes')/100||0.5;
  const wCon=n('p_wCon')/100||0.5;
  let totalCoins=0;
  let rowsHtml='';
  cd.contratos.forEach((c,ci)=>{
    const base=nc>0?ma/nc:0;
    const satPassed=(c.satA/100)>=sc.patMin;
    let cCoins=0;
    if(satPassed) cCoins=base*(wRes*kpiMult(c.resA)+wCon*kpiMult(c.conA));
    totalCoins+=cCoins;
    const satCls=satPassed?'p-green':'p-red';
    const satLbl=satPassed?'&#10003;':'&#10007;';
    rowsHtml+=`<tr>
      <td>${ci+1}</td>
      <td><input type="text" value="${c.nome}" style="width:130px;padding:3px 6px;border:1px solid var(--border);border-radius:4px;font-size:12px;" onchange="CD['${p.id}'].contratos[${ci}].nome=this.value;refreshCartCard('${p.id}')"></td>
      <td style="text-align:right">${fCoins(base)}</td>
      <td><input type="number" min="0" max="150" step="1" value="${c.satA}" style="width:65px;padding:3px 6px;border:1px solid var(--border);border-radius:4px;font-size:12px;text-align:right;" oninput="CD['${p.id}'].contratos[${ci}].satA=+this.value;refreshCartCard('${p.id}')"></td>
      <td><span class="pill ${satCls}">${satLbl}</span></td>
      <td><input type="number" min="0" max="150" step="1" value="${c.resA}" style="width:65px;padding:3px 6px;border:1px solid var(--border);border-radius:4px;font-size:12px;text-align:right;" oninput="CD['${p.id}'].contratos[${ci}].resA=+this.value;refreshCartCard('${p.id}')"></td>
      <td><input type="number" min="0" max="150" step="1" value="${c.conA}" style="width:65px;padding:3px 6px;border:1px solid var(--border);border-radius:4px;font-size:12px;text-align:right;" oninput="CD['${p.id}'].contratos[${ci}].conA=+this.value;refreshCartCard('${p.id}')"></td>
      <td style="text-align:right;font-weight:700">${fCoins(cCoins)}</td>
      <td><button class="btn-del" onclick="delContrato('${p.id}',${ci})">&#128465;</button></td>
    </tr>`;
  });

  return `<div class="cart-card" id="cc_${p.id}">
    <div class="cart-hdr">
      <span>${p.nome} &mdash; ${p.cargo}</span>
    </div>
    <div class="cart-body">
      <div class="ig">
        <label>Moedas ajustadas (gest&atilde;o)<br><span style="font-weight:400;font-style:italic;font-size:11px;">ajuste por churn / contratos cancelados</span></label>
        <input type="number" min="0" value="${ma}" id="ma_${p.id}" oninput="CD['${p.id}'].moedasAjustadas=+this.value;refreshCartCard('${p.id}')">
        <span class="unit">moedas &nbsp;|&nbsp; base: ${fCoins(p.m*p.wK)}</span>
      </div>
      <div class="cart-summary" id="cs_${p.id}">
        <strong>${nc}</strong> contratos ativos &nbsp;|&nbsp;
        <strong>${approved}</strong> aprovados em satisfa&ccedil;&atilde;o &nbsp;|&nbsp;
        Moedas carteira: <strong>${fCoins(totalCoins)}</strong> / ${fCoins(ma)}
      </div>
      <div style="overflow-x:auto;">
        <table class="tbl" id="ct_${p.id}">
          <thead><tr>
            <th>#</th><th>Nome do Contrato</th><th>Moedas base</th>
            <th>Satisfa&ccedil;&atilde;o %</th><th>Status</th>
            <th>Resultado %</th><th>Conformidade %</th><th>Moedas</th><th></th>
          </tr></thead>
          <tbody>${rowsHtml}</tbody>
        </table>
      </div>
      <button class="btn-add" onclick="addContrato('${p.id}')">+ Adicionar Contrato</button>
    </div>
  </div>`;
}

function addContrato(pid){
  if(!CD[pid]) CD[pid]={moedasAjustadas:0,contratos:[]};
  CD[pid].contratos.push({nome:'Contrato '+(CD[pid].contratos.length+1),satA:100,resA:100,conA:100});
  refreshCartCard(pid);
  recalc();
}

function delContrato(pid,ci){
  CD[pid].contratos.splice(ci,1);
  refreshCartCard(pid);
  recalc();
}

function refreshCartCard(pid){
  const p=E.find(x=>x.id===pid);
  if(!p) return;
  const cd=CD[pid]||{moedasAjustadas:p.m*p.wK,contratos:[]};
  const container=document.getElementById('cc_'+pid);
  if(!container) return;
  const newHtml=buildCartCard(p,cd);
  container.outerHTML=newHtml;
  recalc();
}

